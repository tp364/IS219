    "toolkit",
    "openai",
    "web-search"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^16.3.1",
    "openai": "^4.38.0",
    "yargs": "^17.7.2",
    "playwright": "^1.40.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "vitest": "^0.34.0",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2"
  }
}
