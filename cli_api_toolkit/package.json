{
  "name": "cli-ai-toolkit",
  "version": "1.0.0",
  "description": "Industry-standard CLI application for AI-powered tools with extensible command architecture",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "clean": "node -e \"require('fs').rmSync('dist', {recursive: true, force: true})\"",
    "prebuild": "npm run clean"
  },
  "keywords": [
